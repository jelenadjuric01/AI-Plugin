<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.github.jelenadjuric01.gitmuse</id>
    <name>Git Muse</name>
    <vendor>jelenadjuric01</vendor>
    <description><![CDATA[
        <p><b>Git Muse</b> generates Conventional Commits messages from your staged diff using an LLM.</p>
        <p>Adds a button to the Commit dialog: click it, and a clear, format-correct commit message appears in the message field for you to review and edit before committing. Works with any OpenAI-compatible endpoint — OpenAI, Groq's free tier, a local Ollama server, OpenRouter, and others — configured in <i>Settings &rarr; Tools &rarr; Git Muse</i>.</p>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.vcs</depends>

    <resource-bundle>messages.GitMuseBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <applicationService
            serviceImplementation="com.github.jelenadjuric01.gitmuse.settings.GitMuseSettings"/>
        <applicationConfigurable
            parentId="tools"
            id="com.github.jelenadjuric01.gitmuse.settings"
            displayName="Git Muse"
            instance="com.github.jelenadjuric01.gitmuse.settings.GitMuseSettingsConfigurable"/>
        <projectService
            serviceImplementation="com.github.jelenadjuric01.gitmuse.service.CommitMessageService"/>
        <notificationGroup
            id="Git Muse"
            displayType="BALLOON"
            isLogByDefault="false"/>
    </extensions>

    <actions>
        <action
            id="com.github.jelenadjuric01.gitmuse.GenerateCommitMessage"
            class="com.github.jelenadjuric01.gitmuse.action.GenerateCommitMessageAction"
            text="Generate AI Commit Message"
            description="Generate a Conventional Commits message from the staged diff using an LLM"
            icon="AllIcons.Actions.Lightning">
            <add-to-group group-id="Vcs.MessageActionGroup" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
